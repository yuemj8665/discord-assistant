# ─────────────────────────────────────────
# Discord 봇 설정
# ─────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
COMMAND_PREFIX=!

# ─────────────────────────────────────────
# 파일 접근 허용 폴더 (쉼표 구분)
# ─────────────────────────────────────────
ALLOWED_DIRS=/path/to/dir1,/path/to/dir2

# ─────────────────────────────────────────
# Google Calendar MCP
# ─────────────────────────────────────────
# Google Cloud Console에서 발급한 OAuth 2.0 클라이언트 자격증명 파일 경로
GOOGLE_OAUTH_CREDENTIALS=/path/to/credentials.json
# google-calendar-mcp 바이너리 경로 (npm install -g @cocal/google-calendar-mcp)
GOOGLE_CALENDAR_MCP_BIN=/opt/homebrew/bin/google-calendar-mcp
# 프로젝트 venv Python 경로
VENV_PYTHON=/path/to/project/venv/bin/python3

# ─────────────────────────────────────────
# 채널 → 세션 매핑
# ─────────────────────────────────────────
GENERAL_CHANNEL_ID=your_general_channel_id
CALENDAR_CHANNEL_ID=your_calendar_channel_id
SESSION_CHANNEL_ID=your_session_channel_id

# ─────────────────────────────────────────
# 알림 설정
# ─────────────────────────────────────────
# 일정 알림을 받을 채널 ID
NOTIFY_CHANNEL_ID=your_notify_channel_id
# Discord 유저 ID (@멘션 대상)
DISCORD_USER_ID=your_discord_user_id
# 일정 몇 분 전에 알림 보낼지
NOTIFY_MINUTES_BEFORE=30

# ─────────────────────────────────────────
# IT 뉴스
# ─────────────────────────────────────────
NEWS_CHANNEL_ID=your_news_channel_id
# 뉴스 전송 시각 (KST 기준, 0~23)
NEWS_HOUR=6
# 사이트별 최대 수집 개수
NEWS_MAX_ITEMS=10

# ─────────────────────────────────────────
# 인프라 모니터링
# ─────────────────────────────────────────
INFRA_CHANNEL_ID=your_infra_channel_id
# 임계값 초과 시 경보 (%)
INFRA_CPU_THRESHOLD=80
INFRA_MEMORY_THRESHOLD=85
INFRA_DISK_THRESHOLD=90
# 리소스 체크 주기 (초)
INFRA_CHECK_INTERVAL=300
# 일일 리포트 시각 (KST 기준)
INFRA_DAILY_REPORT_HOUR=6
INFRA_DAILY_REPORT_MINUTE=15
